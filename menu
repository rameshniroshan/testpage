  { t: 'menu', s: 'Drinks', items: [
    { n: 'Mango Lassi',     d: 'Chilled alphonso mango blended with creamy natural yoghurt',
      i: 'https://upload.wikimedia.org/wikipedia/commons/thumb/3/37/Mango_Lassi.jpg/320px-Mango_Lassi.jpg', p: [300,400,500] },
    { n: 'Ceylon Iced Tea', d: 'Premium loose-leaf Ceylon black tea, chilled & lightly sweetened',
      i: 'https://upload.wikimedia.org/wikipedia/commons/thumb/9/9d/Shrimp_fried_rice.jpg/320px-Shrimp_fried_rice.jpg', p: [250,350,450] },
    { n: 'Fresh Lime Soda', d: 'Freshly squeezed lime with chilled soda water & pinch of salt',
      i: 'https://upload.wikimedia.org/wikipedia/commons/thumb/9/9d/Shrimp_fried_rice.jpg/320px-Shrimp_fried_rice.jpg', p: [200,300,400] },
  ]},

  { t: 'backcover' },
];

const N = PAGES.length; // total pages

/* ═══════════════════════════════════════════════════
   BUILD PAGE INNER HTML
═══════════════════════════════════════════════════ */
function buildHTML(data, pgNum) {
  if (data.t === 'cover') return `
    <div class="cover">
      <div class="cvglow"></div>
      <div class="cvorn">✦ ✦ ✦</div>
      <div class="cvtitle">Our Menu</div>
      <div class="cvrule"></div>
      <div class="cvsub">Fine Sri Lankan Cuisine</div>
      <div class="cvfoot">Est. 2005 · Colombo</div>
    </div>`;

  if (data.t === 'backcover') return `
    <div class="bcover">
      <div class="cvorn" style="color:var(--gd)">✦</div>
      <div class="bcT">Thank You</div>
      <div class="bcS">We hope to see you again</div>
      <div class="bcP">+94 11 234 5678</div>
    </div>`;

  const rs = n => 'Rs. ' + n.toLocaleString();
  const esc = s => s.replace(/'/g, "\\'");
  return `
    <div class="pscroll">
      <div class="mpage">
        <div class="shead">
          <span class="stitle">${data.s}</span>
          <div class="srule"></div>
        </div>
        ${data.items.map(it => `
          <div class="item">
            <img class="fi" src="${it.i}" alt="${it.n}" loading="lazy"
              onerror="this.src='';this.style.background='#ddd'">
            <div class="ib">
              <div class="iname">${it.n}</div>
              <div class="idesc">${it.d}</div>
              <div class="ptns">
                <button class="pb" onclick="addItem('${esc(it.n)}','Small',${it.p[0]})">S · ${rs(it.p[0])}</button>
                <button class="pb" onclick="addItem('${esc(it.n)}','Medium',${it.p[1]})">M · ${rs(it.p[1])}</button>
                <button class="pb" onclick="addItem('${esc(it.n)}','Large',${it.p[2]})">L · ${rs(it.p[2])}</button>
              </div>
            </div>
          </div>`).join('')}
      </div>
    </div>
    ${pgNum ? `<span class="pgn">${pgNum}</span>` : ''}`;
}

/* ═══════════════════════════════════════════════════
   CREATE ALL STATIC PAGE ELEMENTS
═══════════════════════════════════════════════════ */
const pageWrap = document.getElementById('pageWrap');
PAGES.forEach((data, i) => {
  const el = document.createElement('div');
  el.className = 'page';
  el.id = 'page' + i;
  el.innerHTML = buildHTML(data, i > 0 && i < N - 1 ? i : '');
  pageWrap.appendChild(el);
});

/* ═══════════════════════════════════════════════════
   PAGE FLIP ENGINE

   State:
     cur  = index of the page currently showing on top
   
   Flip direction:
     FORWARD  (cur → cur+1):
       flipPanel rotates 0 → -180 around left axis.
       Front face shows page[cur].
       Back face shows page[cur+1].
       After complete: cur++, reset panel.

     BACKWARD (cur → cur-1):
       flipPanel rotates -180 → 0.
       Front face shows page[cur-1].  (it comes back into view)
       Back face shows page[cur].
       After complete: cur--, reset panel.

   The flip panel sits above the static stack.
   While flipping, the source static page is hidden (opacity 0)
   so only the flip panel's front face is visible.
═══════════════════════════════════════════════════ */

let cur = 0;          // current visible page index
let busy = false;     // animation in progress
let dragging = false;
let dragFwd = null;   // true = forward, false = backward
let touchStartX = 0, touchStartY = 0;
let touchCurX   = 0, touchCurY   = 0;
let currentAngle = 0; // current rotateY angle of flipPanel (0 = flat, -180 = fully turned)

const book        = document.getElementById('book');
const flipPanel   = document.getElementById('flipPanel');
const flipFront   = document.getElementById('flipFront');
const flipBack    = document.getElementById('flipBack');
const flipFrontC  = document.getElementById('flipFrontContent');
const flipBackC   = document.getElementById('flipBackContent');
const cornerGrab  = document.getElementById('cornerGrab');

/* Set the 3D angle of the flip panel.
   angle: 0 = flat (face-up), -180 = fully flipped (face-down to left) */
function applyAngle(angle) {
  currentAngle = angle;
  // perspective on the parent keeps it consistent
  flipPanel.style.transform = `perspective(1400px) rotateY(${angle}deg)`;
}

/* Restack static pages after a flip completes */
function restack() {
  PAGES.forEach((_, i) => {
    const el = document.getElementById('page' + i);
    if (!el) return;
    if (i < cur) {
      // already-read pages sit below
      el.style.zIndex = i + 1;
      el.style.display = 'block';
      el.style.opacity = '1';
    } else if (i === cur) {
      // current top page
      el.style.zIndex = N + 2;
      el.style.display = 'block';
      el.style.opacity = '1';
    } else {
      // upcoming pages stacked below current
      el.style.zIndex = N + 1 - (i - cur);
      el.style.display = i <= cur + 3 ? 'block' : 'none';
      el.style.opacity = '1';
    }
  });
  updateDots();
  updateHint();
}

/* Show the flip panel, populate its faces, hide the source static page */
function beginFlip(forward) {
  dragFwd = forward;

  const frontPageIdx = forward ? cur     : cur - 1;  // page that peels away
  const backPageIdx  = forward ? cur + 1 : cur;      // page revealed on back

  flipFrontC.innerHTML = buildHTML(PAGES[frontPageIdx],
    frontPageIdx > 0 && frontPageIdx < N - 1 ? frontPageIdx : '');
  flipBackC.innerHTML  = buildHTML(PAGES[backPageIdx],
    backPageIdx  > 0 && backPageIdx  < N - 1 ? backPageIdx  : '');

  // Position panel above everything
  flipPanel.style.display  = 'block';
  flipPanel.style.zIndex   = '60';

  // Start angle: 0 for forward, -180 for backward
  applyAngle(forward ? 0 : -180);

  // Hide the static page that the flip panel is covering
  const srcEl = document.getElementById('page' + frontPageIdx);
  if (srcEl) srcEl.style.opacity = '0';
}

/* Hide the flip panel and restore static pages */
function endFlip() {
  flipPanel.style.display = 'none';
  applyAngle(0);
  restack(); // restores all opacities and z-indices
}

/* Easing: ease-in-out quad */
const easeInOut = t => t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;

/* Animate from current angle to target angle, then call done() */
function animateTo(fromAngle, toAngle, done) {
  busy = true;
  const duration = 120 + Math.abs(toAngle - fromAngle) / 180 * 340; // faster for small remaining
  const t0 = performance.now();

  (function tick(now) {
    const t = Math.min(1, (now - t0) / duration);
    applyAngle(fromAngle + (toAngle - fromAngle) * easeInOut(t));
    if (t < 1) {
      requestAnimationFrame(tick);
    } else {
      busy = false;
      done();
    }
  })(t0);
}

/* ── TOUCH / MOUSE HANDLING ──────────────────────── */

/*
  Hot zone: bottom-right 40% × 40% of the book = grab to go forward
            bottom-left  30% × 40%             = grab to go backward
*/
function getZone(clientX, clientY) {
  const r = book.getBoundingClientRect();
  const rx = clientX - r.left;
  const ry = clientY - r.top;
  const bw = r.width, bh = r.height;
  if (rx > bw * 0.55 && ry > bh * 0.55 && cur < N - 1) return 'fwd';
  if (rx < bw * 0.45 && ry > bh * 0.55 && cur > 0)    return 'bwd';
  return null;
}

/*
  Map current touch position to a flip angle (0 → -180).
  As the finger moves from the right side toward the left,
  the angle goes from 0 toward -180.
*/
function touchToAngle(clientX) {
  const r  = book.getBoundingClientRect();
  const dx = clientX - r.left; // 0 = left edge, bw = right edge
  const bw = r.width;
  // when finger is at right (bw) → angle = 0
  // when finger is at left  (0)  → angle = -180
  const ratio = 1 - Math.max(0, Math.min(1, dx / bw));
  return -ratio * 180;
}

function onPointerDown(clientX, clientY) {
  if (busy) return;
  const zone = getZone(clientX, clientY);
  if (!zone) return;

  dragging = true;
  touchStartX = touchCurX = clientX;
  touchStartY = touchCurY = clientY;

  beginFlip(zone === 'fwd');
}

function onPointerMove(clientX, clientY) {
  if (!dragging || busy) return;
  touchCurX = clientX;
  touchCurY = clientY;

  let angle = touchToAngle(clientX);

  if (dragFwd) {
    // Forward: 0 → -180. Clamp so it can't go positive or past -180.
    angle = Math.max(-180, Math.min(0, angle));
  } else {
    // Backward: started at -180, finger moves right toward 0.
    // Map rightward movement back toward 0.
    const r  = book.getBoundingClientRect();
    const dx = clientX - touchStartX; // positive = moved right
    const bw = r.width;
    const ratio = Math.max(0, Math.min(1, dx / bw));
    angle = -180 + ratio * 180;
  }

  applyAngle(angle);
}

function onPointerUp() {
  if (!dragging) return;
  dragging = false;

  const angle = currentAngle; // where the finger released

  if (dragFwd) {
    // Commit if turned past -60° (33%), otherwise snap back
    if (angle < -60) {
      animateTo(angle, -180, () => {
        cur++;
        endFlip();
      });
    } else {
      animateTo(angle, 0, () => endFlip());
    }
  } else {
    // Backward: commit if returned past -120° (33% of the way back), else snap back
    if (angle > -120) {
      animateTo(angle, 0, () => {
        cur--;
        endFlip();
      });
    } else {
      animateTo(angle, -180, () => endFlip());
    }
  }
}

/* Touch events */
book.addEventListener('touchstart', e => {
  const t = e.touches[0];
  onPointerDown(t.clientX, t.clientY);
}, { passive: true });

book.addEventListener('touchmove', e => {
  if (dragging) e.preventDefault();
  const t = e.touches[0];
  onPointerMove(t.clientX, t.clientY);
}, { passive: false });

book.addEventListener('touchend',   () => onPointerUp(), { passive: true });
book.addEventListener('touchcancel',() => onPointerUp(), { passive: true });

/* Mouse events (desktop fallback) */
let mouseDown = false;
book.addEventListener('mousedown', e => {
  mouseDown = true;
  onPointerDown(e.clientX, e.clientY);
});
window.addEventListener('mousemove', e => {
  if (mouseDown) onPointerMove(e.clientX, e.clientY);
});
window.addEventListener('mouseup', () => {
  if (mouseDown) { mouseDown = false; onPointerUp(); }
});

/* Corner affordance glow on hover */
book.addEventListener('mousemove', e => {
  const zone = getZone(e.clientX, e.clientY);
  cornerGrab.classList.toggle('hot', zone === 'fwd');
  document.getElementById('cornerLabel').style.opacity = zone === 'fwd' ? '0.7' : '0';
});
book.addEventListener('mouseleave', () => {
  cornerGrab.classList.remove('hot');
  document.getElementById('cornerLabel').style.opacity = '0';
});

/* ── DOTS & HINT ──────────────────────────────────── */
function updateDots() {
  const row = document.getElementById('dotRow');
  row.innerHTML = PAGES.map((_, i) =>
    `<div class="dot${i === cur ? ' active' : ''}"></div>`
  ).join('');
}

function updateHint() {
  const el = document.getElementById('hintText');
  if (cur === 0)     el.textContent = 'Drag bottom-right corner to turn';
  else if (cur === N - 1) el.textContent = 'Drag bottom-left to go back';
  else               el.textContent = 'Drag corners to turn pages';
}

/* ═══════════════════════════════════════════════════
   CART
═══════════════════════════════════════════════════ */
let cart = [], uid = 0;

function addItem(name, size, price) {
  cart.push({ id: uid++, name, size, price });
  renderCart();
  showToast(name + ' added');
}

function removeItem(id) {
  cart = cart.filter(i => i.id !== id);
  renderCart();
}

function clearCart() {
  cart = [];
  renderCart();
}

function placeOrder() {
  if (!cart.length) { showToast('Cart is empty!'); return; }
  showToast('Order placed! Thank you ✦');
  setTimeout(() => { clearCart(); closeCart(); }, 1400);
}

function renderCart() {
  const list  = document.getElementById('cartList');
  const empty = document.getElementById('cartEmpty');
  const badge = document.getElementById('fabBadge');
  const total = document.getElementById('cartTotal');
  empty.style.display = cart.length ? 'none' : 'block';
  badge.style.display = cart.length ? 'flex' : 'none';
  badge.textContent   = cart.length;
  const rs = n => 'Rs. ' + n.toLocaleString();
  list.innerHTML = cart.map(i => `
    <div class="citem">
      <div class="cinfo">
        <div class="cname">${i.name}</div>
        <div class="csize">${i.size}</div>
      </div>
      <span class="cprice">${rs(i.price)}</span>
      <button class="crmbtn" onclick="removeItem(${i.id})">✕</button>
    </div>`).join('');
  total.textContent = rs(cart.reduce((s, i) => s + i.price, 0));
}

function openCart()  { document.getElementById('overlay').classList.add('open'); document.getElementById('drawer').classList.add('open'); }
function closeCart() { document.getElementById('overlay').classList.remove('open'); document.getElementById('drawer').classList.remove('open'); }

/* ── TOAST ──────────────────────────────────────── */
let toastTimer;
function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2200);
}

/* ── INIT ──────────────────────────────────────── */
restack();
</script>
</body>
</html>
